generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  category    Category
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Category {
  auto
  real_estate
  electronics
}
